PORT=3000

# You can use either DATABASE_URL or the DB_* fields below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/six_seven_bot

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=six_seven_bot
DB_SSL=false

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_THINKING_LEVEL=low
GEMINI_TEMPERATURE=0.9
GEMINI_MAX_OUTPUT_TOKENS=320

BOT_TOKEN=
BOT_USERNAME=
BOT_REPLY_CHANCE=0.03
BOT_REPLY_COOLDOWN_MS=15000
MAX_MESSAGE_LENGTH=2000
RECENT_MESSAGES_LIMIT=50
STYLE_SAMPLE_LIMIT=1000
MIN_STYLE_MESSAGES=20
STYLE_REBUILD_EVERY_MESSAGES=100
